# Backend Port
PORT=9100

# Database Connection
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=investment_db
DB_HOST=localhost
DB_PORT=5432

# PostgreSQL Environment Variables
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=investment_db
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Node Environment
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRATION=24h

# Token Encryption
TOKEN_ENCRYPTION_KEY=your_32_byte_hex_encryption_key_here

# API Keys - External Services
QUESTRADE_REFRESH_TOKEN=<questrade_refresh_token_here>
ALPHAVANTAGE_API_KEY=<alphavantage_api_key_here>
YAHOO_FINANCE_API_KEY=<yahoo_finance_api_key_here>

# Redis (Optional - for distributed rate limiting)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Google OAuth (Optional)
GOOGLE_CLIENT_ID=<google_client_id_here>
GOOGLE_CLIENT_SECRET=<google_client_secret_here>

# Rate Limiting
RATE_LIMIT_GENERAL_MAX=100
RATE_LIMIT_GENERAL_WINDOW_MS=900000
RATE_LIMIT_AUTH_MAX=5
RATE_LIMIT_AUTH_WINDOW_MS=900000

# Email Configuration (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=<your_email@gmail.com>
SMTP_PASSWORD=<your_app_password>

# Logging
LOG_LEVEL=debug
