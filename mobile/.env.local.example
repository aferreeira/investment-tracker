# Backend API Configuration
# Set this to your machine's local network IP for testing on a real device
# For iOS simulator: http://localhost:9100
# For Android emulator: http://10.0.2.2:9100  
# For real device on same Wi-Fi: http://<your-machine-ip>:9100 (e.g., http://192.168.1.100:9100)
API_BASE_URL=http://10.0.0.168:9100

# Google OAuth Configuration
# Web Client ID - obtained from Google Cloud Console (for backend token verification)
# Keep this private - only needed on backend, but app needs it for validation
GOOGLE_WEB_CLIENT_ID=''

# iOS Client ID - obtained from Google Cloud Console
# This is specific to the bundle ID "com.investmenttracker.mobile"
# Create a new OAuth 2.0 Client ID in Google Cloud Console:
# - Application Type: iOS
# - Bundle ID: com.investmenttracker.mobile
GOOGLE_IOS_CLIENT_ID=''
